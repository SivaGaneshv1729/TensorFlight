# AgriHUD Backend Configuration
# Change SIMULATOR_MODE to False when connecting to real hardware
SIMULATOR_MODE=True

# Hardware configuration
# Simulator UDP: udpin:0.0.0.0:14551
# Real Hardware (Windows): COM3
# Real Hardware (Linux): /dev/ttyUSB0
MAVLINK_URL=udpin:0.0.0.0:14551

# Video stream source
# Simulator: 0 (or just leave it empty when SIMULATOR_MODE=True)
# Real Hardware RTSP: rtsp://192.168.1.10:8554/stream
VIDEO_SOURCE=0
